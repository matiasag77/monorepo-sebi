# ─── Proyecto GCP ─────────────────────────────────────────────────────
project_id  = "tu-proyecto-gcp"
region      = "us-central1"
environment = "prod"

# ─── Secretos (usar un archivo .tfvars separado o variables de entorno)
# NUNCA commitear estos valores reales
mongodb_uri              = "mongodb+srv://user:pass@cluster.mongodb.net/sebi-chatbot?retryWrites=true&w=majority"
jwt_secret               = "cambiar-por-un-secreto-seguro"
nextauth_secret          = "cambiar-por-un-secreto-seguro"
google_oauth_client_id   = "tu-client-id.apps.googleusercontent.com"
google_oauth_client_secret = "tu-client-secret"
admin_password           = "cambiar-por-password-seguro"

# ─── Configuración de servicios ───────────────────────────────────────
adk_api_url      = "https://sebi-adk-xxxxxxxx.us-central1.run.app"
admin_email      = "admin@sebi.com"
bigquery_dataset = "sebi_chatbot"
bigquery_table   = "conversation_traces"
jwt_expiration   = "2h"

# ─── Scaling ──────────────────────────────────────────────────────────
api_max_instances      = 5
frontend_max_instances = 5

# ─── GitHub (para Cloud Build triggers) ───────────────────────────────
github_owner = "tu-usuario-github"
github_repo  = "monorepo-sebi"
