# ─── General ───────────────────────────────────────────────────
NODE_ENV=development

# ─── Puertos (opcionales, tienen defaults) ─────────────────────
API_PORT=3333
FRONTEND_PORT=3000

# ─── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRATION=2h

# ─── Google OAuth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── NextAuth ──────────────────────────────────────────────────
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3333/api
FRONTEND_URL=http://localhost:3000

# ─── Admin seed ────────────────────────────────────────────────
ADMIN_EMAIL=admin@sebi.com
ADMIN_PASSWORD=change-me

# ─── BigQuery ──────────────────────────────────────────────────
BIGQUERY_PROJECT_ID=your-gcp-project-id
BIGQUERY_KEY_FILE=
BIGQUERY_DATASET=sebi_chatbot
BIGQUERY_TABLE=conversation_traces

# ─── ADK Cloud Run ────────────────────────────────────────────
# URL del Cloud Run del ADK (externo). La api-bff genera un identity token
# automáticamente usando la Service Account con permiso Cloud Run Invoker.
ADK_API_URL=https://sebi-adk-xxxxxxxx.us-central1.run.app
