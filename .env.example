# ─── General ───────────────────────────────────────────────────
NODE_ENV=development

# ─── Puertos (opcionales, tienen defaults) ─────────────────────
API_PORT=3333
FRONTEND_PORT=3000
ADK_PORT=8000

# ─── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRATION=2h

# ─── Google OAuth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── NextAuth ──────────────────────────────────────────────────
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3333/api
FRONTEND_URL=http://localhost:3000

# ─── Admin seed ────────────────────────────────────────────────
ADMIN_EMAIL=admin@sebi.com
ADMIN_PASSWORD=change-me

# ─── BigQuery ──────────────────────────────────────────────────
BIGQUERY_PROJECT_ID=your-gcp-project-id
BIGQUERY_KEY_FILE=
BIGQUERY_DATASET=sebi_chatbot
BIGQUERY_TABLE=conversation_traces

# ─── Proveedor de IA ──────────────────────────────────────────
# Opciones: "skelligen" o "adk"
AI_PROVIDER=skelligen
SKELLIGEN_API_URL=https://skelligen-api.prod.interno.forus-sistemas.com/api/test-ai

# ─── Google Cloud / ADK ───────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# Ruta local a la carpeta con el archivo sa-key.json
GCP_SA_KEY_PATH=./credentials

# ─── Pub/Sub (solo si usas el perfil "pubsub") ────────────────
PUBSUB_SUBSCRIPTION_ID=your-subscription-id
PUBSUB_RESPONSE_TOPIC_ID=your-response-topic-id
