# Server
PORT=3333
FRONTEND_URL=http://localhost:3000

# Database
MONGODB_URI=mongodb://localhost:27017/sebi-chatbot

# JWT
JWT_SECRET=xxx

# Google OAuth
GOOGLE_CLIENT_ID=xxx
GOOGLE_CLIENT_SECRET=xxx

# BigQuery
BIGQUERY_PROJECT_ID=xxx
# Opción 1: ruta al archivo JSON de la service account (desarrollo local)
BIGQUERY_KEY_FILE=./credentials/service-account.json
# Opción 2: contenido JSON de la service account como string (Cloud Run / Secret Manager)
# BIGQUERY_CREDENTIALS_JSON=xxx
BIGQUERY_DATASET=test_logs
BIGQUERY_TABLE=web_test

# ADK Cloud Run
ADK_API_URL=xxx
# APP_NAME=SEBI
# FALLBACK_API_URL=https://skelligen-api.prod.interno.forus-sistemas.com/api/test-ai

# GCP Auth — Workload Identity Federation (producción en EKS)
# USE_WORKLOAD_IDENTITY=true
# WORKLOAD_IDENTITY_AUDIENCE=//iam.googleapis.com/projects/<PROJECT_NUMBER>/locations/global/workloadIdentityPools/<POOL>/providers/<PROVIDER>
# GOOGLE_SERVICE_ACCOUNT_EMAIL=sebi-app-prod@your-project.iam.gserviceaccount.com
# AWS_WEB_IDENTITY_TOKEN_FILE=/var/run/secrets/eks.amazonaws.com/serviceaccount/token

# GCP Auth — Archivo de credenciales (alternativa local, aplica para BigQuery y Cloud Run)
# GOOGLE_KEY_FILE=./credentials/service-account.json

# Swagger — habilitado por defecto, desactivar con false
# SWAGGER_ENABLED=true
